fn get_pair(): (int, str) {
    return (42, "hello");
}

fn use_tuple(t: (int, float)): void {
    print(t.0);
    print(t.1);
}

fn main(): void {
    let t: (int, float) = (1, 3.14);
    print(t.0);
    print(t.1);

    let p: (int, str) = get_pair();
    print(p.0);
    print(p.1);

    use_tuple((10, 2.5));

    let triple: (int, int, int) = (100, 200, 300);
    print(triple.0);
    print(triple.1);
    print(triple.2);

    // Tuple destructuring
    let (x, y): (int, str) = get_pair();
    print(x);
    print(y);

    let (a, b, c): (int, int, int) = (10, 20, 30);
    print(a);
    print(b);
    print(c);
}
